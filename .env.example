# ==========================================
# FEMABRAS — ENVIRONMENT VARIABLES EXAMPLE
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ==========================================

# ── Database ──────────────────────────────
# Local dev:    host=localhost user=xxx password=xxx dbname=xxx port=5432 sslmode=disable
# Railway prod: postgresql://postgres:xxx@postgres.railway.internal:5432/railway
DATABASE_URL=host=localhost user=xxxxxx password=xxxxxx dbname=xxxxxx port=5432 sslmode=disable

# ── Redis ─────────────────────────────────
# Local dev:  redis://:YOUR_REDIS_PASSWORD@localhost:6379/0
# Railway:    redis://default:xxx@redis.railway.internal:6379
REDIS_URL=redis://:xxxxxx@localhost:6379/0
REDIS_PASSWORD=xxxxxx


# ── Server ────────────────────────────────
PORT=8080

# ── Frontend ──────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080

# ── Auth ──────────────────────────────────
# JWT_SECRET must be at least 32 random characters
JWT_SECRET=xxxxxx
ENCRYPTION_KEY=xxxxxx

# ── Google OAuth ──────────────────────────
GOOGLE_CLIENT_ID=xxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxx
GOOGLE_REDIRECT_URL=http://localhost:8080/auth/google/callback

# ── Email (Resend) ────────────────────────
RESEND_API_KEY=xxxxxx

# ── SMTP (admin alerts via Gmail relay) ───
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=youraddress@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
FROM_EMAIL=youraddress@gmail.com
ADMIN_EMAIL=youraddress@gmail.com
APP_NAME=Femabras Daily Challenge

# ── Ad Network ────────────────────────────
# S2S secret provided by your ad network dashboard
AD_NETWORK_SECRET=xxxxxx
NEXT_PUBLIC_GAM_AD_UNIT_PATH=xxxxxx

# ── Twilio (SMS fallback — optional) ──────
TWILIO_SID=xxxxxx
TWILIO_AUTH_TOKEN=xxxxxx
TWILIO_PHONE_NUMBER=xxxxxx