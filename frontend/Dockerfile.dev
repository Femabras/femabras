FROM node:22-alpine

WORKDIR /app

# Enable pnpm
RUN corepack enable && corepack prepare pnpm@latest --activate

# Cache dependencies
COPY package.json pnpm-lock.yaml* ./
RUN pnpm install

# We DO NOT copy the source code here. The docker-compose bind mount handles it.

EXPOSE 3000

# Run Next.js in development mode for Instant HMR
CMD ["pnpm", "dev"]