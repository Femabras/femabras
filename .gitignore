# ==========================================
# FEMABRAS MONOREPO .GITIGNORE
# ==========================================

# --- OS & Editor Files ---
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# --- Environment Secrets ---
.env
.env.local
.env.*
!.env.example
*.pem

# --- Global Logs & Temp Files ---
tmp/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# ==========================================
# FRONTEND (Next.js / Node)
# ==========================================
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/coverage/
.vercel/
*.tsbuildinfo

# Note: next-env.d.ts is NOT ignored. It should be committed.

# ==========================================
# BACKEND (Go)
# ==========================================
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out

# Backend local builds
backend/bin/
backend/tmp/
backend/main
backend/server
backend/tests/